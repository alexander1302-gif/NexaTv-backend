# Estas variables las crea Vercel automáticamente cuando conectas
# una base de datos KV desde el dashboard (Storage -> Create Database -> KV).
# No las necesitas escribir a mano salvo que estés probando en local
# con `vercel env pull`.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Secreto para autorizar llamadas a /api/sync (cron de Vercel lo manda
# automáticamente; para llamadas manuales o externas, pásalo como
# ?secret=... o como header Authorization: Bearer <valor>).
# Genera uno con: openssl rand -hex 24
CRON_SECRET=
